<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#0B0F19"
    android:gravity="top">

    <!-- App Title Banner -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="BlinkScript Assistant"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#3B82F6"
        android:gravity="center"
        android:layout_marginTop="5dp"
        android:layout_marginBottom="10dp"/>

    <!-- State Indicator -->
    <TextView
        android:id="@+id/txtStateIndicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="MODE: HOME"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#94A3B8"
        android:background="#1E293B"
        android:paddingHorizontal="12dp"
        android:paddingVertical="4dp"
        android:layout_marginBottom="15dp"/>

    <!-- Conversation/History Screen -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="#151F32"
        android:padding="16dp"
        android:layout_marginBottom="15dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RECENT LOGS / CONVERSATION"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#64748B"
            android:layout_marginBottom="6dp"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">
            
            <TextView
                android:id="@+id/txtHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Welcome to BlinkScript.\nSelect an option below to begin."
                android:textSize="15sp"
                android:textColor="#E2E8F0"
                android:lineSpacingExtra="4dp"/>
        </ScrollView>
    </LinearLayout>

    <!-- Word Suggestions Row -->
    <LinearLayout
        android:id="@+id/suggestionsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1E293B"
        android:padding="10dp"
        android:layout_marginBottom="15dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="WORD SUGGESTIONS (Blink 1, 2, or 3 to select)"
            android:textSize="9sp"
            android:textStyle="bold"
            android:textColor="#94A3B8"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/txtSuggestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="[No suggestions]"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#34D399"/>
    </LinearLayout>

    <!-- Emergency Contact Display (shown during SOS) -->
    <TextView
        android:id="@+id/txtEmergencyContact"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#FCA5A5"
        android:gravity="center"
        android:background="#7F1D1D"
        android:padding="12dp"
        android:layout_marginBottom="10dp"
        android:visibility="gone"/>

    <!-- Main System Prompt / Active Question -->
    <TextView
        android:id="@+id/question"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="How can I help you today?"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:gravity="center"
        android:layout_marginBottom="20dp"
        android:paddingHorizontal="10dp"/>

    <!-- Typing Buffer Display (Shows what is being built in Spell Mode) -->
    <EditText
        android:id="@+id/editMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Custom message buffer..."
        android:textColorHint="#475569"
        android:textColor="#FFFFFF"
        android:background="#0F172A"
        android:padding="12dp"
        android:focusable="false"
        android:clickable="false"
        android:layout_marginBottom="15dp"
        android:gravity="center"
        android:textSize="18sp"
        android:visibility="gone"/>

    <!-- Option Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <Button
            android:id="@+id/btn1"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="[1] Health"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#2563EB"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn2"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="[2] Daily Needs"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#2563EB"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn3"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="[3] Entertainment"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#2563EB"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn4"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="[4] Emergency"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#DC2626"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnSend"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="Send Message"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#10B981"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp"
            android:visibility="gone"/>

    </LinearLayout>

</LinearLayout>